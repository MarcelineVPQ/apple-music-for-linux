{
  "name": "apple-music-for-linux",
  "author": "Marcus Tomlinson",
  "version": "0.8.0",
  "description": "Apple Music for Linux",
  "main": "main.js",
  "scripts": {
    "start": "bash start.sh",
    "dist": "electron-builder --linux AppImage",
    "dist:snap": "electron-builder --linux snap"
  },
  "build": {
    "electronVersion": "42.3.3+wvcus",
    "electronDownload": {
      "mirror": "https://github.com/castlabs/electron-releases/releases/download/"
    },
    "appId": "apple-music-for-linux",
    "productName": "Apple Music",
    "files": [
      "main.js",
      "miniplayer.html",
      "lyrics.html",
      "lastfm.js",
      "discord.js",
      "apple-music-for-linux.png"
    ],
    "linux": {
      "target": ["AppImage"],
      "icon": "apple-music-for-linux.png",
      "category": "Audio",
      "artifactName": "${name}-${version}-${arch}.${ext}",
      "desktop": {
        "entry": {
          "StartupWMClass": "apple-music-for-linux"
        }
      }
    },
    "snap": {
      "grade": "stable",
      "confinement": "strict",
      "plugs": [
        "audio-playback",
        "browser-support",
        "desktop",
        "desktop-legacy",
        "home",
        "network",
        "opengl",
        "x11"
      ],
      "slots": [
        { "mpris": { "name": "chromium" } }
      ]
    }
  },
  "repository": "https://github.com/MarcelineVPQ/apple-music-for-linux",
  "license": "GPL-3.0",
  "devDependencies": {
    "electron": "https://github.com/castlabs/electron-releases#v42.3.3+wvcus",
    "electron-builder": "^26.0.12"
  }
}
